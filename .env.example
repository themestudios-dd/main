# Copy this file to `.env.local` for local development.
# For local production-style builds, you can also use `.env`.
# In GitHub Actions, provide the same keys as repository secrets instead.

# Optional social proof
VITE_FACEBOOK_PAGE_URL=

# Disabled by default Meta Pixel scaffolding
VITE_META_PIXEL_ID=
VITE_ENABLE_META_PIXEL=false

# Server-side Mailjet variables for the PHP contact endpoint.
# Do not expose these in frontend code.
MAILJET_API_KEY=
MAILJET_API_SECRET=
MAILJET_FROM_EMAIL=support@themestudios.in
MAILJET_FROM_NAME=ThemeStudios Website
CONTACT_TO_EMAIL=support@themestudios.in
CONTACT_TO_NAME=ThemeStudios Support
